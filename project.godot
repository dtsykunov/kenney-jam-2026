;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Kenney Jam"
run/main_scene="res://scenes/opening/opening.tscn"
config/features=PackedStringArray("4.7")

[autoload]

